          <material>
            <ambient>0 1.0  0 1.0</ambient>
            <diffuse>0 1.0  0 1.0</diffuse>
          </material>
        </visual>
      </link>
      <plugin name="radiation_source_plugin" filename="libradiation_source_plugin.so">
