    <plugin name="obstacle_plugin" filename="libradiation_obstacle_plugin.so">
      <material_type>boratedConcrete</material_type>
    </plugin>
  </model>

  <model name="radiation_obstacle_tankSet4_stainlessSteel_1">
    <pose>-0.60 3.70 2.6831 0 0 0</pose>
    <static>true</static>
